# HackFlow Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# FLASK CONFIGURATION
# ============================================
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=change-this-to-secure-random-key

# Port for Cloud Run (default: 8080)
PORT=8080

# ============================================
# SUPABASE CONFIGURATION
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# IMPORTANT: Update this to your Cloud Run URL AFTER deployment
# Format: https://your-service-123456.run.app/auth/google/callback
GOOGLE_REDIRECT_URI=https://your-cloud-run-url.run.app/auth/google/callback

# For local development, uncomment:
# GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# ============================================
# RATE LIMITING
# ============================================
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URL=memory://

# ============================================
# SESSION CONFIGURATION
# ============================================
# Set to true in production with HTTPS
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=86400

# ============================================
# SECURITY
# ============================================
BCRYPT_LOG_ROUNDS=12
WTF_CSRF_ENABLED=true